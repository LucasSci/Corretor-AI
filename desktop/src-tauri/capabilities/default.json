{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/corretor-backend",
          "sidecar": true,
          "args": [
            "--host",
            { "validator": "\\S+" },
            "--port",
            { "validator": "\\d+" },
            "--settings-path",
            { "validator": ".+" }
          ]
        }
      ]
    }
  ]
}
