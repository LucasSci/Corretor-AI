# FastAPI
APP_NAME=CorretorIA
PORT=8000

# Database
DB_URL=sqlite+aiosqlite:///./data/app.db

# Gemini AI API
GEMINI_API_KEY=your_gemini_api_key_here
MODEL_NAME=gemini-2.5-flash
AI_TEMPERATURE=0.6
CHROMA_K=4

# Evolution API (WhatsApp)
URL_EVOLUTION=http://localhost:8080
API_KEY_EVOLUTION=your_evolution_api_key_here
EVOLUTION_INSTANCE=BotRiva1

# WhatsApp Testing bypass
WHATSAPP_TEST_NUMBER=your_test_phone_number_here
WHATSAPP_BOT_NUMBER=your_bot_phone_number_here
ALLOW_FROM_ME_TEST=True
WEBHOOK_LOOP_GUARD_TTL_SEC=30
